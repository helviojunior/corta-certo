# Copie para .env e ajuste conforme necessário.

# Modo online/público (hospedagem pública).
#   0 = padrão (auto-hospedado): todos os projetos aparecem na lista, sem cookie.
#   1 = online: cada visitante recebe um cookie de sessão; a lista mostra só os
#       projetos do dono do cookie, e editar/excluir exige ser o dono.
#       (Visualizar por link /p/<id> continua aberto — os projetos são públicos.)
ONLINE_MODE=0
